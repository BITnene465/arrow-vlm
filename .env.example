# Copy to .env and adjust if needed.
# 这里放机器/环境相关的基础配置；实验配置仍建议写在 yaml 中，由 yaml 覆盖这些值。

VLM_DET_MODEL_NAME_OR_PATH=models/Qwen3-VL-2B-Instruct
VLM_DET_REMOTE_MODEL_NAME_OR_PATH=Qwen/Qwen3-VL-2B-Instruct
VLM_DET_OUTPUT_DIR=outputs/qwen3_vl_arrow_sft
VLM_DET_WANDB_PROJECT=vlm_det

# Optional runtime overrides
# VLM_DET_MODEL_MIN_PIXELS=
# VLM_DET_MODEL_MAX_PIXELS=
# VLM_DET_USE_WANDB=true

# Hugging Face runtime cache
# HF_HOME=.cache/huggingface
# TRANSFORMERS_CACHE=.cache/huggingface/transformers
